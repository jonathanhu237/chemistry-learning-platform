# Copy to .env for docker-compose or local production-style runs.

# development | production
CHEMISTRY_APP_ENV=development

# Postgres runtime storage. In production this must be explicit.
DATA_BACKEND=postgres
DATABASE_URL=postgresql+psycopg://chemistry:chemistry@postgres:5432/chemistry_exam
RUN_DB_CHECK_ON_STARTUP=false
# Docker Compose exposes Postgres to the host on 15432 by default to avoid
# colliding with a developer's local Postgres on 5432. Containers still use
# postgres:5432 through the Compose network.
POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=15432

# Local media storage for uploaded videos/resources.
MEDIA_ROOT=/app/data/media
MAX_MEDIA_UPLOAD_MB=8192
MAX_MEDIA_SUBTITLE_UPLOAD_MB=10
TUS_UPLOAD_DIR=tus
TUS_PUBLIC_ENDPOINT=http://127.0.0.1:10980/files/
VIDEO_WORKER_POLL_SECONDS=5
VIDEO_WORKER_ID=local-video-worker
VIDEO_LEARNING_MAX_WIDTH=1280
VIDEO_LEARNING_CRF=24
VIDEO_LEARNING_MAX_FPS=30
VIDEO_LEARNING_TRANSCODE_THRESHOLD_MB=300
VIDEO_TRANSCODE_ACCELERATION=auto
VIDEO_DUPLICATE_DETECTION_ALGORITHM=vpdq-threatexchange-1.2.16
VIDEO_DUPLICATE_DETECTION_COMMAND=python -m server.app.video_similarity vpdq-signature "{input}" "{output}" "{seconds_per_hash}"
VIDEO_DUPLICATE_DETECTION_COMPARE_COMMAND=python -m server.app.video_similarity vpdq-compare "{current}" "{candidate}"
VIDEO_DUPLICATE_DETECTION_THRESHOLD=0.95
VIDEO_DUPLICATE_DEFAULT_INTERVAL_SECONDS=3
VIDEO_DUPLICATE_MIN_SAMPLES=12
VIDEO_DUPLICATE_MIN_INTERVAL_SECONDS=0.5
VIDEO_DUPLICATE_DURATION_TOLERANCE_RATIO=0.001
VIDEO_DUPLICATE_DURATION_TOLERANCE_FLOOR_SECONDS=0.5
VIDEO_DUPLICATE_DURATION_TOLERANCE_CEILING_SECONDS=2.0

# Online textbook ingestion. OCR and embedding credentials are environment-only;
# never store provider keys in platform settings or commit them here.
TEXTBOOK_INGESTION_ENABLED=true
TEXTBOOK_STORAGE_ROOT=/app/data/textbooks
MAX_TEXTBOOK_UPLOAD_MB=200
MAX_TEXTBOOK_PAGES=1000
TEXTBOOK_INGESTION_WORKER_ID=local-textbook-ingestion-worker
TEXTBOOK_INGESTION_WORKER_POLL_SECONDS=5
TEXTBOOK_INGESTION_LEASE_SECONDS=300
TEXTBOOK_NATIVE_MIN_CHARS=80
TEXTBOOK_NATIVE_MIN_PRINTABLE_RATIO=0.85
TEXTBOOK_CHUNK_MAX_CHARS=1800
TEXTBOOK_CHUNK_OVERLAP_CHARS=180
TEXTBOOK_EMBEDDING_BATCH_SIZE=16
TEXTBOOK_INDEX_BATCH_SIZE=64
TEXTBOOK_OCR_ENABLED=false
TEXTBOOK_OCR_BASE_URL=https://aigw.sysu.edu.cn/v1
TEXTBOOK_OCR_API_KEY=
TEXTBOOK_OCR_MODEL=mineru
TEXTBOOK_OCR_TIMEOUT_SECONDS=90
TEXTBOOK_OCR_CONCURRENCY=2
TEXTBOOK_OCR_MAX_RETRIES=3
TEXTBOOK_OCR_RENDER_DPI=160
# When enabled, a corpus publish/deactivate also queues refresh jobs for existing point evidence.
CATALOG_POINT_EVIDENCE_AUTO_REFRESH=false

# Public API origin shown to web clients.
API_PUBLIC_BASE_URL=http://127.0.0.1:8000
FRONTEND_ALLOWED_ORIGINS=http://222.200.189.249:5173,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175,http://localhost:5176,http://127.0.0.1:5176,http://localhost:5177,http://127.0.0.1:5177,http://222.200.189.249:15176,http://localhost:15176,http://127.0.0.1:15176,http://localhost:15177,http://127.0.0.1:15177
STUDENT_PREVIEW_APP_BASE_URL=http://222.200.189.249:5173
STUDENT_PREVIEW_ALLOWED_ORIGINS=http://222.200.189.249:5173,http://localhost:5173,http://127.0.0.1:5173
STUDENT_PREVIEW_TICKET_EXPIRE_MINUTES=10
STUDENT_PREVIEW_SESSION_EXPIRE_MINUTES=240
WEB_STUDENT_HOST_BIND=222.200.189.249
WEB_STUDENT_HOST_PORT=5173
WEB_TEACHER_HOST_BIND=127.0.0.1
WEB_TEACHER_HOST_PORT=5174
WEB_ADMIN_HOST_BIND=127.0.0.1
WEB_ADMIN_HOST_PORT=5175
WEB_STUDENT_OLD_HOST_BIND=222.200.189.249
WEB_STUDENT_OLD_HOST_PORT=15176
WEB_TEACHER_OLD_HOST_BIND=127.0.0.1
WEB_TEACHER_OLD_HOST_PORT=15177

# Auth. Use a long random value in production.
AUTH_SECRET_KEY=dev-only-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=720
# web-admin uses this config token directly instead of an app_users login.
# Production must replace it with a long random value.
WEB_ADMIN_ACCESS_TOKEN=dev-only-web-admin-token-change-me

# Assistant resource lookup and external textbook RAG.
# Core chunks/embeddings import from data/seed; CHEMISTRY_RAG_ROOT is only for optional source image assets.
RAG_QUERY_GENERATION_ENABLED=true
RAG_KEYWORD_TOP_K=16
RAG_FINAL_TOP_K=5
CHEMISTRY_RAG_ROOT=/chemistry-rag

TEXTBOOK_RAG_ENABLED=false
TEXTBOOK_RAG_ELASTICSEARCH_URL=http://elasticsearch:9200
TEXTBOOK_RAG_ELASTICSEARCH_INDEX=canonical-rag-chunks-qwen-v1
# Alibaba Cloud Model Studio / DashScope example. Do not commit real keys.
TEXTBOOK_RAG_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TEXTBOOK_RAG_EMBEDDING_API_KEY=
TEXTBOOK_RAG_EMBEDDING_MODEL=text-embedding-v4
TEXTBOOK_RAG_EMBEDDING_DIMENSION=1024
TEXTBOOK_RAG_KEYWORD_TOP_K=16
TEXTBOOK_RAG_VECTOR_TOP_K=24
TEXTBOOK_RAG_RERANK_TOP_K=9
TEXTBOOK_RAG_FINAL_TOP_K=5
TEXTBOOK_RAG_RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
TEXTBOOK_RAG_RERANK_API_KEY=
TEXTBOOK_RAG_RERANK_MODEL=qwen3-rerank
TEXTBOOK_RAG_MIN_RERANK_SCORE=0
TEXTBOOK_RAG_TIMEOUT_SECONDS=8

# Agent/LLM. Use disabled for deterministic local fallback until a provider is configured.
# DeepSeek OpenAI-compatible example. Do not commit real keys.
AGENT_LLM_PROVIDER=openai
AGENT_LLM_BASE_URL=https://api.deepseek.com
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=deepseek-chat

# Student experiment video-library search.
# Production must use Elasticsearch with IK analysis and must not enable local fallback.
VIDEO_LIBRARY_SEARCH_ENABLED=true
VIDEO_LIBRARY_SEARCH_BACKEND=elasticsearch
VIDEO_LIBRARY_SEARCH_URL=http://elasticsearch:9200
VIDEO_LIBRARY_SEARCH_INDEX=student-video-library
VIDEO_LIBRARY_SEARCH_ANALYZER=ik_max_word
VIDEO_LIBRARY_SEARCH_BOOTSTRAP_INDEX=true
VIDEO_LIBRARY_SEARCH_TIMEOUT_SECONDS=3
VIDEO_LIBRARY_SEARCH_LOCAL_FALLBACK=true
VIDEO_LIBRARY_SEARCH_REQUIRE_ES_IN_PRODUCTION=true
ELASTICSEARCH_HOST_BIND=127.0.0.1
ELASTICSEARCH_HOST_PORT=9200

# Compatibility with the existing RAG implementation.
OPENAI_API_KEY=
OPENAI_MODEL=
LLM_API_KEY=
LLM_MODEL=
