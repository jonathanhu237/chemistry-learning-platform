# Copy to .env for docker-compose or local production-style runs.

# development | production
CHEMISTRY_APP_ENV=development

# Postgres runtime storage. In production this must be explicit.
DATA_BACKEND=postgres
DATABASE_URL=postgresql+psycopg://chemistry:chemistry@postgres:5432/chemistry_exam
RUN_DB_CHECK_ON_STARTUP=false

# Local media storage for uploaded videos/resources.
MEDIA_ROOT=/app/data/media
MAX_MEDIA_UPLOAD_MB=1024

# Public API origin shown to admin clients.
API_PUBLIC_BASE_URL=http://127.0.0.1:8000
FRONTEND_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:5173
ADMIN_WEB_DIST=/app/apps/admin-web/dist

# Auth. Use a long random value in production.
AUTH_SECRET_KEY=dev-only-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Agent/LLM. Use disabled for deterministic local fallback until a provider is configured.
AGENT_LLM_PROVIDER=disabled
AGENT_LLM_BASE_URL=
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=

# Compatibility with the existing RAG implementation.
OPENAI_API_KEY=
OPENAI_MODEL=
LLM_API_KEY=
LLM_MODEL=
