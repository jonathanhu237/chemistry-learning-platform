FROM python:3.12-slim@sha256:090ba77e2958f6af52a5341f788b50b032dd4ca28377d2893dcf1ecbdfdfe203 AS ffmpeg

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

ARG TARGETARCH
ARG FFMPEG_URL=
ARG FFMPEG_SHA256=
ARG FFMPEG_LOCAL_ARCHIVE=

COPY server/vendor/ffmpeg/ /opt/ffmpeg-cache/

RUN python - <<'PY'
import hashlib
import json
import os
import platform
import shutil
import stat
import tarfile
import tempfile
import time
import urllib.request
from pathlib import Path

target_arch = (os.environ.get("TARGETARCH") or "").strip()
if not target_arch:
    target_arch = {
        "aarch64": "arm64",
        "x86_64": "amd64",
    }.get(platform.machine().lower(), "")

asset_arch = {
    "amd64": "linux64",
    "arm64": "linuxarm64",
}.get(target_arch)
if not asset_arch:
    raise RuntimeError(
        f"Unsupported FFmpeg target architecture {target_arch!r}; "
        "set FFMPEG_URL and extend the architecture validation before building"
    )

asset_name = f"ffmpeg-master-latest-{asset_arch}-gpl.tar.xz"
default_url = (
    "https://github.com/BtbN/FFmpeg-Builds/releases/download/latest/"
    f"{asset_name}"
)
url = (os.environ.get("FFMPEG_URL") or "").strip()
expected_sha256 = (os.environ.get("FFMPEG_SHA256") or "").removeprefix("sha256:").strip()
local_archive = os.environ.get("FFMPEG_LOCAL_ARCHIVE", "").strip()
cache_dir = Path("/opt/ffmpeg-cache")
archive = Path(tempfile.gettempdir()) / "ffmpeg.tar.xz"
extract_dir = Path(tempfile.gettempdir()) / "ffmpeg"
extract_dir.mkdir(parents=True, exist_ok=True)

local_candidates = []
if local_archive:
    local_candidates.append(cache_dir / local_archive)
local_candidates.extend(sorted(cache_dir.glob(f"*-{asset_arch}-*.tar.xz")))
local_candidates.extend(
    candidate
    for candidate in sorted(cache_dir.glob("*.tar.xz"))
    if candidate not in local_candidates
)

for candidate in local_candidates:
    if candidate.is_file():
        if not expected_sha256:
            raise RuntimeError(
                "FFMPEG_SHA256 is required when building from a local FFmpeg archive"
            )
        shutil.copy2(candidate, archive)
        source = str(candidate)
        break
else:
    if not url and not expected_sha256:
        metadata_request = urllib.request.Request(
            "https://api.github.com/repos/BtbN/FFmpeg-Builds/releases/tags/latest",
            headers={
                "Accept": "application/vnd.github+json",
                "User-Agent": "chemistry-video-worker-build",
                "X-GitHub-Api-Version": "2022-11-28",
            },
        )
        with urllib.request.urlopen(metadata_request, timeout=60) as response:
            release = json.load(response)
        asset = next(
            (item for item in release.get("assets", []) if item.get("name") == asset_name),
            None,
        )
        if asset is None:
            raise RuntimeError(f"{asset_name} is missing from the upstream latest release")
        url = str(asset.get("browser_download_url") or default_url)
        expected_sha256 = str(asset.get("digest") or "").removeprefix("sha256:").strip()
        if not expected_sha256:
            raise RuntimeError(f"Upstream release metadata has no sha256 digest for {asset_name}")
    elif not url:
        url = default_url
    elif not expected_sha256:
        raise RuntimeError("FFMPEG_SHA256 is required when overriding FFMPEG_URL")

    request = urllib.request.Request(url, headers={"User-Agent": "chemistry-video-worker-build"})
    last_error = None
    for attempt in range(1, 6):
        try:
            with urllib.request.urlopen(request, timeout=120) as response, archive.open("wb") as file:
                shutil.copyfileobj(response, file)
            last_error = None
            break
        except Exception as exc:
            last_error = exc
            if archive.exists():
                archive.unlink()
            time.sleep(min(attempt * 3, 15))
    if last_error is not None:
        raise last_error
    source = url

if expected_sha256:
    actual_sha256 = hashlib.sha256(archive.read_bytes()).hexdigest()
    if actual_sha256 != expected_sha256:
        raise RuntimeError(
            f"FFmpeg archive sha256 mismatch: expected {expected_sha256}, got {actual_sha256}"
        )

with tarfile.open(archive, "r:xz") as tar:
    tar.extractall(extract_dir, filter="data")

for binary in ("ffmpeg", "ffprobe"):
    matches = list(extract_dir.glob(f"**/bin/{binary}"))
    if not matches:
        raise RuntimeError(f"{binary} not found in {source}")
    with matches[0].open("rb") as binary_file:
        header = binary_file.read(20)
    if len(header) < 20 or header[:4] != b"\x7fELF" or header[5] not in (1, 2):
        raise RuntimeError(f"{binary} from {source} is not a supported ELF binary")
    byteorder = "little" if header[5] == 1 else "big"
    actual_machine = int.from_bytes(header[18:20], byteorder)
    expected_machine = {"amd64": 62, "arm64": 183}[target_arch]
    if actual_machine != expected_machine:
        raise RuntimeError(
            f"{binary} from {source} does not match Docker TARGETARCH={target_arch}"
        )
    target = Path("/usr/local/bin") / binary
    shutil.copy2(matches[0], target)
    target.chmod(target.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)
PY

FROM python:3.12-slim@sha256:090ba77e2958f6af52a5341f788b50b032dd4ca28377d2893dcf1ecbdfdfe203 AS worker-wheels

ARG PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
ARG PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
ARG DEBIAN_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/debian

WORKDIR /build

RUN sed -i "s|http://deb.debian.org/debian|${DEBIAN_MIRROR}|g; s|http://deb.debian.org/debian-security|${DEBIAN_MIRROR}-security|g" /etc/apt/sources.list.d/debian.sources \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
      build-essential \
      cmake \
      pkg-config \
      python3-dev \
      libavcodec-dev \
      libavformat-dev \
      libavdevice-dev \
      libavutil-dev \
      libswscale-dev \
      libswresample-dev \
      libavfilter-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-worker.txt ./
RUN pip wheel --no-cache-dir \
      --retries 8 \
      --timeout 120 \
      --index-url "${PIP_INDEX_URL}" \
      --trusted-host "${PIP_TRUSTED_HOST}" \
      --wheel-dir /wheels \
      -r requirements-worker.txt

FROM python:3.12-slim@sha256:090ba77e2958f6af52a5341f788b50b032dd4ca28377d2893dcf1ecbdfdfe203

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ARG DEBIAN_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/debian

WORKDIR /app

RUN sed -i "s|http://deb.debian.org/debian|${DEBIAN_MIRROR}|g; s|http://deb.debian.org/debian-security|${DEBIAN_MIRROR}-security|g" /etc/apt/sources.list.d/debian.sources \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
      libavcodec61 \
      libavformat61 \
      libavdevice61 \
      libavutil59 \
      libswscale8 \
      libswresample5 \
      libavfilter10 \
      libgomp1 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ffmpeg /usr/local/bin/ffmpeg /usr/local/bin/ffmpeg
COPY --from=ffmpeg /usr/local/bin/ffprobe /usr/local/bin/ffprobe

COPY requirements-worker.txt ./
COPY --from=worker-wheels /wheels /wheels
RUN pip install --no-cache-dir \
      --no-index \
      --find-links /wheels \
      -r requirements-worker.txt
RUN rm -rf /wheels

COPY server ./server

CMD ["python", "-m", "server.app.workers.video_worker"]
