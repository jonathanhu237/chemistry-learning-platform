FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV HF_HOME=/models
ENV TRANSFORMERS_CACHE=/models

WORKDIR /app

COPY requirements-bge.txt ./
RUN pip install --no-cache-dir -r requirements-bge.txt

COPY server ./server

EXPOSE 8010

CMD ["uvicorn", "server.app.bge_service:app", "--host", "0.0.0.0", "--port", "8010"]
